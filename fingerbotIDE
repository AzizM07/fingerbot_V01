void handleRoot() {
  server.send(200, "text/html", html_page);
}

void handleSave() {
  if (server.hasArg("ssid") && server.hasArg("password")) {
    saved_ssid = server.arg("ssid");
    saved_password = server.arg("password");
    
    saveWiFiCredentials(saved_ssid, saved_password);
    server.send(200, "text/html", success_page);
    
    delay(2000);
    ESP.restart();
  } else {
    server.send(400, "text/plain", "Erreur");
  }
}

void startHotspot() {
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ap_ssid, ap_password);
  
  server.on("/", handleRoot);
  server.on("/save", HTTP_POST, handleSave);
  server.begin();
}

bool connectWiFi() {
  if (saved_ssid.length() == 0) return false;
  
  WiFi.mode(WIFI_STA);
  WiFi.begin(saved_ssid.c_str(), saved_password.c_str());
  
  int tentatives = 0;
  while (WiFi.status() != WL_CONNECTED && tentatives < 20) {
    delay(500);
    tentatives++;
    yield();
  }
  
  return (WiFi.status() == WL_CONNECTED);
}


void handleNewMessages(int numNewMessages) {
  if (numNewMessages == 0) return;
  
  int lastIndex = numNewMessages - 1;
  String chat_id = String(bot.messages[lastIndex].chat_id);
  String text = bot.messages[lastIndex].text;
  String from_name = bot.messages[lastIndex].from_name;
  
  if (text == "/start") {
    String welcome = "🤖 Fingerbot activé !\n\n";
    welcome += "Commandes disponibles :\n";
    welcome += "/press - Appuyer\n";
    welcome += "/release - Relâcher\n";
    welcome += "/tap - Tap rapide\n";
    welcome += "/status - État du servo\n";
    welcome += "/reset - Effacer WiFi";
    bot.sendMessage(chat_id, welcome, "");
  }
  else if (text == "/press") {
    fingerServo.write(SERVO_APPUI);
    servoActif = true;
    bot.sendMessage(chat_id, "✅ Bouton pressé !", "");
  }
  else if (text == "/release") {
    fingerServo.write(SERVO_REPOS);
    servoActif = false;
    bot.sendMessage(chat_id, "✅ Bouton relâché !", "");
  }
  else if (text == "/tap") {
    fingerServo.write(SERVO_APPUI);
    delay(500);
    fingerServo.write(SERVO_REPOS);
    servoActif = false;
    bot.sendMessage(chat_id, "✅ Tap effectué !", "");
  }
  else if (text == "/status") {
    String status = servoActif ? "🟢 Actif (appuyé)" : "⚪ Repos";
    bot.sendMessage(chat_id, status, "");
  }
  else if (text == "/reset") {
    
    EEPROM.begin(EEPROM_SIZE);
    for (int i = 0; i < 200; i++) {
      EEPROM.write(i, 0);
    }
    EEPROM.commit();
    EEPROM.end();
    
    bot.sendMessage(chat_id, "✅ WiFi effacé ! Redémarrage en mode Hotspot...", "");
    delay(2000);
    ESP.restart();
  }
  
  yield();
}

void setup() {
  #ifdef USE_SERIAL
    Serial.begin(115200);
    delay(1000);
    DEBUGLN("\n=== FINGERBOT ===");
  #endif
  
  
  delay(3000);
  
  // Servo
  fingerServo.attach(SERVO_PIN);
  fingerServo.write(SERVO_REPOS);
  delay(500);
  
  // WiFi
  loadWiFiCredentials();
  
  bool connected = false;
  if (saved_ssid.length() > 0) {
    DEBUGLN("Connexion WiFi...");
    connected = connectWiFi();
  }
  
  if (!connected) {
    DEBUGLN("Mode Hotspot");
    startHotspot();
    
    while(true) {
      server.handleClient();
      yield();
      delay(10);
    }
  }
  
  DEBUGLN("WiFi OK");
  
  // Telegram
  secured_client.setInsecure();
  secured_client.setBufferSizes(1024, 1024); // Buffers plus petits
  
  delay(2000);
  
  bot.getUpdates(bot.last_message_received + 1);
  
  DEBUGLN("Bot prêt");
}


unsigned long lastCheck = 0;
unsigned long lastWiFiCheck = 0;

void loop() {
  // WiFi check (toutes les 30s)
  if (millis() - lastWiFiCheck > 30000) {
    if (WiFi.status() != WL_CONNECTED) {
      DEBUGLN("Reconnexion WiFi");
      connectWiFi();
    }
    lastWiFiCheck = millis();
  }
  
  // Messages Telegram (toutes les 1s)
  if (millis() - lastCheck > 1000) {
    yield();
    
    int num = bot.getUpdates(bot.last_message_received + 1);
    
    if (num > 0) {
      DEBUGLN("Message reçu");
      handleNewMessages(num);
    }
    
    lastCheck = millis();
  }
  
  yield();
  delay(50);
}
